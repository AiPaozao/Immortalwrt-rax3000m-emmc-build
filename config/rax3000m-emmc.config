#
# ===== Target: MediaTek Filogic → CMCC RAX3000M eMMC =====
#
CONFIG_TARGET_mediatek=y
CONFIG_TARGET_mediatek_filogic=y
CONFIG_TARGET_mediatek_filogic_DEVICE_cmcc_rax3000m-emmc=y

#
# ===== Base / Network / Firewall =====
#
# 用 dnsmasq-full 替换 dnsmasq（提供更多特性）
CONFIG_PACKAGE_dnsmasq-full=y
# CONFIG_PACKAGE_dnsmasq is not set

CONFIG_PACKAGE_firewall4=y
CONFIG_PACKAGE_nftables=y
CONFIG_PACKAGE_kmod-nf-nathelper=y
CONFIG_PACKAGE_kmod-nf-nathelper-extra=y
CONFIG_PACKAGE_kmod-nft-offload=y
CONFIG_PACKAGE_kmod-crypto-hw-safexcel=y
CONFIG_PACKAGE_kmod-phy-aquantia=y
CONFIG_PACKAGE_kmod-gpio-button-hotplug=y
CONFIG_PACKAGE_kmod-leds-gpio=y
CONFIG_PACKAGE_kmod-usb3=y

#
# ===== Wireless (mt76 开源驱动 — 主线标准) =====
# firmware 会被 kmod-mt7915e 的依赖链自动拉入，无需单独写
CONFIG_PACKAGE_kmod-mt7915e=y
# WED / wireless offload firmware
CONFIG_PACKAGE_mt7981-wo-firmware=y

#
# ===== Storage / Disk / Samba =====
#
CONFIG_PACKAGE_block-mount=y
CONFIG_PACKAGE_automount=y
CONFIG_PACKAGE_f2fsck=y
CONFIG_PACKAGE_mkf2fs=y
CONFIG_PACKAGE_cfdisk=y
CONFIG_PACKAGE_samba4-server=y
CONFIG_PACKAGE_luci-app-samba4=y

#
# ===== LUCI (Web UI) =====
#
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-ssl-openssl=y
# 替代旧的 luci-light+luci-compat 组合（24.10 不再需要 luci-compat）
CONFIG_PACKAGE_luci-i18n-package-manager-zh-cn=y
CONFIG_PACKAGE_luci-i18n-firewall-zh-cn=y
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y
CONFIG_PACKAGE_luci-i18n-diskman-zh-cn=y

#
# ===== Theme: Argon =====
#
CONFIG_PACKAGE_luci-theme-argon=y
CONFIG_PACKAGE_luci-app-argon-config=y

#
# ===== 终端 / 工具 =====
#
CONFIG_PACKAGE_ttyd=y
CONFIG_PACKAGE_luci-app-ttyd=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_jq=y

#
# ===== iStore (可选软件中心 — 从第三方 feed 拉) =====
# 下面 DIY 脚本里会注入对应的 feed
#CONFIG_PACKAGE_luci-app-store=y
CONFIG_PACKAGE_app-meta-ddns-go=y
CONFIG_PACKAGE_luci-i18n-ddns-go-zh-cn=y
CONFIG_PACKAGE_luci-i18n-filebrowser-go-zh-cn=y

#
# ===== Docker (luci-app-dockerman 需要 dockerd 本体) =====
# 如果你不需要 Docker，把下面四行删掉就行
CONFIG_PACKAGE_dockerd=y
CONFIG_PACKAGE_luci-app-dockerman=y
CONFIG_PACKAGE_cgroupfs-mount=y
CONFIG_PACKAGE_kmod-veth=y
